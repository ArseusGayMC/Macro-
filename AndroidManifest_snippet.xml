<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml — Gerekli Eklemeler
    ════════════════════════════════════════

    Aşağıdaki bloğu kendi AndroidManifest.xml dosyanızdaki
    <application> etiketinin içine ekleyin.

    Tam dosya yapısı için alttaki açıklamalara bakın.
-->

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.autoclicker">

    <!--
        ═══════════════════════════════════════════════════════════════
        İZİNLER (Permissions)
        ═══════════════════════════════════════════════════════════════

        BIND_ACCESSIBILITY_SERVICE:
        • Sistemin servisi "erişilebilirlik servisi" olarak tanıması için zorunludur.
        • Kullanıcı tarafından Ayarlar → Erişilebilirlik menüsünden etkinleştirilmelidir.

        Bu izin <uses-permission> ile DEĞİL, <service> bloğu içinde
        android:permission ile tanımlanır (aşağıya bakın).
    -->

    <application
        android:label="@string/app_name"
        android:theme="@style/Theme.AutoClicker">

        <!-- Ana Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            ═══════════════════════════════════════════════════════════
            ACCESS BİLİTY SERVICE TANIMI
            ═══════════════════════════════════════════════════════════

            android:name              → Servis sınıfının tam yolu
            android:permission        → Sadece sistemin bu servisi bağlamasına izin ver
            android:exported          → Sistem tarafından keşfedilebilmesi için true
            android:label             → Ayarlar ekranında gösterilecek isim
            android:description       → Açıklama metni (strings.xml'de tanımlayın)
            meta-data / android:resource → accessibility_service_config.xml dosyasını bağlar
        -->
        <service
            android:name=".AutoClickerService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:description="@string/accessibility_service_description">

            <!-- Bu intent-filter zorunludur; sistem servisi bu filtre ile bulur -->
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <!--
                meta-data: accessibility_service_config.xml dosyasını servise bağlar.
                Bu blok olmadan sistem servisi doğru şekilde yapılandıramaz.
            -->
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>

<!--
    ═══════════════════════════════════════════════════════════════════════
    ADIM ADIM KURULUM REHBERİ
    ═══════════════════════════════════════════════════════════════════════

    1. Dosyaları Yerleştirin:
       ─────────────────────
       app/
       ├── src/main/
       │   ├── java/com/example/autoclicker/
       │   │   ├── AutoClickerService.kt        ← Senaryo 2 servis kodu
       │   │   └── LongPressButton.kt           ← Senaryo 1 Compose kodu
       │   ├── res/xml/
       │   │   └── accessibility_service_config.xml
       │   └── AndroidManifest.xml              ← Yukarıdaki service bloğunu ekleyin

    2. strings.xml Eklemeleri (app/src/main/res/values/strings.xml):
       ──────────────────────────────────────────────────────────────
       <string name="accessibility_service_label">Oto-Tıklayıcı</string>
       <string name="accessibility_service_description">
           Belirtilen koordinatlara otomatik tıklama yapar.
       </string>

    3. build.gradle (Module: app) — Minimum API Kontrolü:
       ────────────────────────────────────────────────────
       android {
           defaultConfig {
               minSdk = 24   // dispatchGesture Android 7.0 (API 24) gerektirir
           }
       }

    4. Kullanıcıdan Manuel Etkinleştirme:
       ────────────────────────────────────
       Ayarlar → Erişilebilirlik → Oto-Tıklayıcı → Etkinleştir

       Kod ile yönlendirmek için:
       ──────────────────────────
       val intent = Intent(Settings.ACTION_ACCESSIBILITY_SETTINGS)
       startActivity(intent)

    5. Servisi Başlatma / Durdurma (Activity'den):
       ─────────────────────────────────────────────
       // Doğrudan servis referansına erişmek için bağlama (bind) kullanın
       // ya da bir BroadcastReceiver/Binder mimarisi kurun.
       // En basit yol: statik companion referans (production'da singleton kullanın)

    ═══════════════════════════════════════════════════════════════════════
    ÖNEMLİ NOTLAR
    ═══════════════════════════════════════════════════════════════════════

    • Play Store Politikası: AccessibilityService kullanan uygulamalar
      Google Play'de incelemeye tabidir. Kullanım amacını açıkça belirtin.

    • Test: Gerçek cihazda test edin; emülatörde gestur koordinatları
      farklı davranabilir.

    • API 24+: dispatchGesture Android 7.0'dan itibaren kullanılabilir.
      Daha eski cihazları destekliyorsanız Build.VERSION.SDK_INT kontrolü ekleyin.
-->
